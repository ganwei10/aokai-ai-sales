# ============================================================
# 奥楷机械 AI 销售自动化系统 — 环境变量示例
# 复制为 .env.local 并填入真实值；不填也能以「演示模式」运行
# ============================================================

# ---- 大模型冷邮件（可选，留空则使用内置模板回退） ----
# 兼容 OpenAI 协议；可指向 DeepSeek / Gemini 兼容网关
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ---- 招聘监控数据源（可选，留空则使用内置模拟信号引擎） ----
# Adzuna 免费 API：https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ---- 持久化（可选，推荐生产开启 Vercel KV） ----
# 在 Vercel 项目里绑定 KV 后会自动注入以下变量
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ---- 邮件投递（可选，留空则仅模拟发送并记录日志） ----
# 例如 Resend / Postmark / SMTP 网关；系统默认进入「已发送」模拟队列
EMAIL_PROVIDER_API_KEY=

# 系统基础 URL（用于生成回调/跳转）
NEXT_PUBLIC_BASE_URL=http://localhost:3000
