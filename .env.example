# ============================================================
# 奥楷机械 AI 销售自动化系统 — 环境变量示例
# 复制为 .env.local 并填入真实值；不填也能以「演示模式」运行
# ============================================================

# ---- 大模型冷邮件（可选，留空则使用内置模板回退） ----
# 兼容 OpenAI 协议；可指向 DeepSeek / Gemini 兼容网关
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ---- 全网搜索数据源（出站扫描）----
# 默认（不填任何 key）即走 DuckDuckGo 免 key 真实联网搜索，可直接产出真实信号。
# 若要更强覆盖，可填下列任一真实搜索 API 的 key：
#   WEB_SEARCH_ENGINE=brave    + WEB_SEARCH_API_KEY=xxx   (Brave Search API)
#   WEB_SEARCH_ENGINE=serp     + WEB_SEARCH_API_KEY=xxx   (SerpAPI)
#   WEB_SEARCH_ENGINE=tavily   + WEB_SEARCH_API_KEY=xxx   (Tavily)
# 留空 WEB_SEARCH_ENGINE 时：有 key 用 Brave，无 key 自动用 DuckDuckGo(真实)。
WEB_SEARCH_ENGINE=duckduckgo
WEB_SEARCH_API_KEY=

# ---- 招聘监控数据源（入站发现）----
# Adzuna 免费 API（需注册）：https://developer.adzuna.com/
# 填了才会拉真实招聘职位；留空则使用内置模拟招聘信号引擎。
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ---- 持久化（可选，推荐生产开启 Vercel KV） ----
# 在 Vercel 项目里绑定 KV 后会自动注入以下变量
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ---- 邮件投递（可选，留空则仅模拟发送并记录日志） ----
# 例如 Resend / Postmark / SMTP 网关；系统默认进入「已发送」模拟队列
EMAIL_PROVIDER_API_KEY=

# 系统基础 URL（用于生成回调/跳转）
NEXT_PUBLIC_BASE_URL=http://localhost:3000
